{
  "log": {
    "level": "warn"
  },
  "dns": {
    "servers": [
      {
        "tag": "local-dns",
        "type": "local",
        "detour": "direct"
      },
      {
        "tag": "remote-dns",
        "type": "https",
        "server": "1.1.1.1",
        "detour": "proxy"
      },
      {
        "tag": "backup-dns",
        "type": "https",
        "server": "8.8.8.8",
        "detour": "proxy"
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "rule_set": "geosite-ads",
        "action": "reject",
        "method": "default"
      },
      {
        "domain_keyword": [
          "ymetrica",
          "hotjar"
        ],
        "action": "reject",
        "method": "default"
      },
      {
        "domain_suffix": [
          "mc.yandex.ru",
          "google-analytics.com",
          "googletagmanager.com",
          "app-measurement.com",
          "doubleclick.net",
          "googlesyndication.com",
          "appcenter.ms",
          "crashlytics.com",
          "sentry.io",
          "amplitude.com",
          "mixpanel.com",
          "adjust.com",
          "appsflyer.com",
          "segment.io"
        ],
        "action": "reject",
        "method": "default"
      },
      {
        "rule_set": "geosite-category-ru",
        "server": "local-dns"
      },
      {
        "domain_suffix": [
          ".ru",
          ".su",
          ".by"
        ],
        "server": "local-dns"
      },
     {
        "domain_keyword": [
          "yandex",
          "yastatic",
          "yadi.sk",
          "xn--80aswg",
          "xn--d1acpjx3f.xn--p1ai",
          "xn--c1avg",
          "xn--80asehdb",
          "xn--p1acf",
          "xn--p1ai",
          "icq",
          "livejournal",
          "microsoft"
        ],
        "server": "local-dns"
      },
      {
        "domain_suffix": [
          "vk.com",
          "userapi.com",
          "vk-cdn.me",
          "mvk.com",
          "vk-cdn.net",
          "vk-portal.net",
          "vk.cc",
          "windowsupdate.com",
          "google.com",
          "live.com",
          "login.live",
          "icloud.com",
          "apple.com",
          "cloudflare.com",
          "akamai.net",
          "firebase.io",
          "firebaseio.com",
          "firebaseapp.com",
          "fcm.googleapis.com",
          "firebaseinstallations.googleapis.com",
          "android.googleapis.com",
          "play-fe.googleapis.com",
          "gstatic.com",
          "googleusercontent.com",
          "play.googleapis.com"
        ],
        "server": "local-dns"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "fakeip"
      }
    ],
    "final": "backup-dns"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "mtu": 1400,
      "auto_route": true,
      "strict_route": true,
      "stack": "mixed"
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "proxy",
      "server": "${SERVER_IP}",
      "server_port": 443,
      "uuid": "${VLESS_UUID}",
      "flow": "xtls-rprx-vision",
      "network": "tcp",
      "tls": {
        "enabled": true,
        "server_name": "${SERVER_SNI}",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "${PUBLIC_KEY}",
          "short_id": "${SHORT_ID}"
        }
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "default_domain_resolver": "remote-dns",
    "rule_set": [
      {
        "tag": "geosite-ads",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-ads-all.srs",
        "download_detour": "proxy"
      },
      {
        "tag": "geosite-category-ru",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-ru.srs",
        "download_detour": "proxy"
      },
      {
        "tag": "geoip-ru",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru.srs",
        "download_detour": "proxy"
      }
    ],
    "rules": [
      {
        "network": "udp",
        "port": 443,
        "action": "reject"
      },
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "rule_set": "geosite-ads",
        "action":"reject"
      },
      {
        "domain_keyword": [
          "ymetrica",
          "hotjar"
        ],
        "action": "reject"
      },
      {
        "domain_suffix": [
          "mc.yandex.ru",
          "google-analytics.com",
          "googletagmanager.com",
          "app-measurement.com",
          "doubleclick.net",
          "googlesyndication.com",
          "appcenter.ms",
          "crashlytics.com",
          "sentry.io",
          "amplitude.com",
          "mixpanel.com",
          "adjust.com",
          "appsflyer.com",
          "segment.io"
        ],
        "action": "reject"
      },
      {
        "rule_set": [
          "geosite-category-ru",
          "geoip-ru"
        ],
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          ".ru",
          ".su",
          ".by"
        ],
        "outbound": "direct"
      },
      {
        "domain_keyword": [
          "yandex",
          "yastatic",
          "yadi.sk",
          "xn--80aswg",
          "xn--d1acpjx3f.xn--p1ai",
          "xn--c1avg",
          "xn--80asehdb",
          "xn--p1acf",
          "xn--p1ai",
          "icq",
          "livejournal",
          "microsoft"
        ],
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          "vk.com",
          "userapi.com",
          "vk-cdn.me",
          "mvk.com",
          "vk-cdn.net",
          "vk-portal.net",
          "vk.cc",
          "windowsupdate.com",
          "google.com",
          "live.com",
          "login.live",
          "icloud.com",
          "apple.com",
          "cloudflare.com",
          "akamai.net",
          "firebase.io",
          "firebaseio.com",
          "firebaseapp.com",
          "fcm.googleapis.com",
          "firebaseinstallations.googleapis.com",
          "android.googleapis.com",
          "play-fe.googleapis.com",
          "gstatic.com",
          "googleusercontent.com",
          "play.googleapis.com"
        ],
        "outbound": "direct"
      }
    ],
    "final": "proxy",
    "auto_detect_interface": true
  }
}
